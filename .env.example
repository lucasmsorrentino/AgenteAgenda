# ============================================
# AgenteAgenda — Configuration
# Copy this file to .env and fill in values
# ============================================

# --- Telegram ---
# Create a bot with @BotFather and paste the token here
TELEGRAM_BOT_TOKEN=your_bot_token_here
# Run the bot, send /start, check logs for your chat_id
TELEGRAM_CHAT_ID=
# Comma-separated extra chat IDs allowed to use the bot (owner is always allowed)
TELEGRAM_ALLOWED_IDS=

# --- Google Calendar ---
# Download OAuth client credentials from Google Cloud Console → OAuth 2.0 Client IDs
# and save to data/credentials.json. The token is generated by setup_google.py.
GOOGLE_CREDENTIALS_PATH=data/credentials.json
GOOGLE_TOKEN_PATH=data/token.json
GOOGLE_CALENDAR_ID=primary

# --- Anytype (local API) ---
# Start Anytype desktop, enable Local API in Settings, then run setup_anytype.py
ANYTYPE_BASE_URL=http://localhost:31009
ANYTYPE_API_KEY=
ANYTYPE_API_VERSION=2025-11-08
ANYTYPE_SPACE_ID=

# --- General ---
TIMEZONE=America/Sao_Paulo
REMINDER_MINUTES_BEFORE=15
